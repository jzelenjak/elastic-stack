# Example .env file for environment variables.
# The file is based on https://github.com/elastic/elasticsearch/blob/main/docs/reference/setup/install/docker/.env

# Default Elastic user
ELASTIC_USER=elastic
# Password for the Elastic user (at least 6 characters)
ELASTIC_PASSWORD=

# Kibana system user
KIBANA_USER=kibana_system
# Password for the Kibana system user (at least 6 characters)
KIBANA_PASSWORD=

# Logstash internal user
LOGSTASH_USER=logstash_internal
# Password for the Logstash internal user (at least 6 characters)
LOGSTASH_PASSWORD=

# Beats internal user
BEATS_USER=beats_internal
# Password for the Logstash internal user (at least 6 characters)
BEATS_PASSWORD=

# Version of Elastic products
STACK_VERSION=9.3.2

# Elasticsearch cluster name
ES_CLUSTER_NAME=docker-cluster

# Set to 'basic' or 'trial' to automatically start the 30-day trial
LICENSE=basic
#LICENSE=trial

# Port to expose Elasticsearch HTTP API to the host
ES_PORT=9200
#ES_PORT=127.0.0.1:9200

# Port to expose Kibana to the host
KIBANA_PORT=5601

# NOTE: Generate the keys with the ./generate_kibana_keys.sh script
# Alternatively, run `bin/kibana-encryption-keys generate` inside Kibana container
# Use at least 32-byte-long strong encryption keys
KIBANA_ENCRYPTED_SAVED_OBJECTS_ENCRYPTION_KEY=
KIBANA_REPORTING_ENCRYPTION_KEY=
KIBANA_SECURITY_ENCRYPTION_KEY=

# Memory limits (in bytes)
# Increase or decrease based on the available host memory
# 1 GiB = 1073741824, 2 GiB = 2147483648
# MEM_LIMIT=1073741824
ES_MEM_LIMIT=1073741824
KB_MEM_LIMIT=1073741824
LS_MEM_LIMIT=1073741824

# Project namespace (defaults to the current folder name if not set)
COMPOSE_PROJECT_NAME=elastic
